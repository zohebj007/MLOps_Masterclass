{
    "bucket": "main-sagemaker-ml-healthcare",
    "prefix": "mlops",
    "region": "ap-south-1",
    "role": "arn:aws:iam::account-id:role/role-name",
    "preprocessing_instance_type": "ml.m5.large",
    "training_instance_type": "ml.m5.large",
    "evaluation_instance_type": "ml.m5.large",
    "model_package_group_name": "diabetes",
    "input_data_default": "s3://main-sagemaker-ml-healthcare/mlops/diabetes.csv",
    "train_output_path": "s3://main-sagemaker-ml-healthcare/mlops/train",
    "test_output_path": "s3://main-sagemaker-ml-healthcare/mlops/test",
    "val_output_path": "s3://main-sagemaker-ml-healthcare/mlops/val",
    "model_output_uri": "s3://main-sagemaker-ml-healthcare/mlops/output",
    "evaluation_output_uri": "s3://main-sagemaker-ml-healthcare/output/evaluation",
    "framework_version_sklearn": "1.2-1",
    "framework_version_xgboost": "1.0-1",
    "instance_count": 1,
    "py_version": "py3",
    "hyperparameters": {
        "n_estimators": 50,
        "max_depth": 5
    }
}